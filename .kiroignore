# Ignore all docs content by default
**/*.md
**/*.mdx
**/*.rst
**/*.txt

# Ignore docs folders
docs/**
documentation/**
content/**
guides/**
reference/**

# Ignore static assets
**/*.png
**/*.jpg
**/*.jpeg
**/*.svg
**/*.gif
**/*.webp
**/*.pdf

# Ignore generated files
build/**
dist/**
.out/**
.cache/**
.next/**
.docusaurus/**
.vitepress/**
.mintlify/**
.storybook/**
.tmp/**
.temp/**

# Ignore configs that explode context
**/*.json
**/*.yml
**/*.yaml

# Ignore lockfiles
**/package-lock.json
**/pnpm-lock.yaml
**/yarn.lock

# Ignore node_modules
node_modules/**

# Ignore git metadata
.git/**