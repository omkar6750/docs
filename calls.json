{
  "openapi": "3.1.0",
  "info": {
    "title": "calls-api",
    "version": "3"
  },
  "servers": [
    {
      "url": "https://{appId}.call-{region}.cometchat.io/v3",
      "variables": {
        "appId": {
          "default": "appId"
        },
        "region": {
          "default": "region"
        }
      }
    }
